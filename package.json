{
  "name": "chainmind",
  "author": "bij7n",
  "version": "0.0.1",
  "description": "Next & TypeScript",
  "private": true,
  "scripts": {
    "dev": "next dev -p 7500",
    "start": "next start -p 7500",
    "prebuild": "bun run lint && bun run format",
    "build": "bun run codegen && next build",
    "postbuild": "next-sitemap",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --apply ./src",
    "format": "biome format --write ./src",
    "clear-all": "rm -rf node_modules .next out dist build",
    "re-start": "rm -rf node_modules .next out dist build && bun install && bun run dev",
    "re-build": "rm -rf node_modules .next out dist build && bun install && bun run build",
    "codegen": "ts-node codegenScript.ts && bun run format && bun run lint:fix",
    "icongen": "ts-node icongen.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
