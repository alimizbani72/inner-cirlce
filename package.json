{
  "name": "chainmind-v2-front",
  "author": "chainmind-frontiers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 7500",
    "build": "next build",
    "start": "next start -p 7500",
    "dev:build": "next build",
    "prebuild": "bun run ignore-type",
    "codegen": "orval --config orval.config.ts",
    "icongen": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/icongen.ts && bun forlint",
    "translate": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/translate.ts",
    "build:translations": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/build-translations.ts",
    "ignore-type": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/ignore-ts-errors.ts",
    "clear-all": "rm -rf node_modules .next out dist build",
    "re-start": "rm -rf node_modules .next out dist build && bun install && bun run dev",
    "dictgen": "bun run translate && bun run build:translations",
    "re-build": "rm -rf node_modules .next out dist build && bun install && bun run build"
  },
